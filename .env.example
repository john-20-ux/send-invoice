# Ruby app runtime
PORT=3000
BIND_ADDRESS=0.0.0.0
HOST=http://localhost:3000

# Storage: set DATABASE_URL to use PostgreSQL (production); leave it blank to
# use the local SQLite file at DATABASE_PATH (dev/test).
# DATABASE_URL=postgres://user:pass@host:5432/send_invoice
DATABASE_PATH=ruby_app/db/send_invoice.sqlite3
# Postgres connection pool size (per process) when DATABASE_URL is set.
DB_POOL=5

# Set to true to force demo data mode.
MOCK_MODE=true

# Optional Shopify credentials for real OAuth + sync mode
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_orders
SHOPIFY_API_VERSION=2026-04

# Slack OAuth v2 (Connect Slack on the Notifications page). Create a Slack app,
# add the incoming-webhook scope, and set the redirect URL to
# {HOST}/auth/slack/callback. Leave blank to hide the real connect flow.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# Bot Token Scopes. chat:write + chat:write.public lets the app post to any
# public channel (and private channels the app is invited to) via
# chat.postMessage. channels:read + groups:read power the channel picker
# (conversations.list). Use "incoming-webhook" instead to post to a single
# channel the user picks at install time.
SLACK_SCOPES=chat:write,chat:write.public,channels:read,groups:read

# WhatsApp — Meta Cloud API. Business-level credentials (one number for the whole
# app). Get these from the Meta app dashboard → WhatsApp → API Setup. Note: a
# free-form message only sends within 24h of the recipient's last message;
# outside that window Meta requires a pre-approved template.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v21.0

# Basecamp — OAuth 2. Register an app at https://launchpad.37signals.com/integrations
# and set its redirect URI to {HOST}/auth/basecamp/callback. Basecamp requires a
# descriptive User-Agent with a contact address on every API request.
BASECAMP_CLIENT_ID=
BASECAMP_CLIENT_SECRET=
BASECAMP_USER_AGENT=Send Invoice (you@example.com)

# Encrypts access/refresh tokens at rest (AES-256-GCM). REQUIRED in production.
# Generate one with: ruby -rsecurerandom -e 'puts SecureRandom.hex(32)'
ENCRYPTION_KEY=

# Opt into Shopify expiring offline access tokens + auto-refresh (recommended;
# becomes the default in 2026). Set to "false" to keep permanent tokens.
EXPIRING_OFFLINE_TOKENS=true

# Order webhooks (ORDERS_CREATE/UPDATED/EDITED) carry protected customer data and
# require approved Protected Customer Data access in the Partner Dashboard. Leave
# false until that access is granted; scheduled bulk sync covers orders meanwhile.
ENABLE_ORDER_WEBHOOKS=false

# Optional automated sync
AUTO_SYNC_ENABLED=false
AUTO_SYNC_INTERVAL_SECONDS=300
SYNC_API_SECRET=

# Observability
APP_ENV=development
# Optional Slack-compatible incoming webhook for error alerts (secrets/PII are
# redacted before sending). Leave blank to log-only.
ERROR_WEBHOOK_URL=

# Protected Customer Data retention: delete synced orders (which carry customer
# PII) older than this many days. 0 = keep indefinitely. See docs.
ORDER_RETENTION_DAYS=0

# Billing: create Shopify TEST charges (no real money) unless set to "false".
# Defaults to test everywhere except production (APP_ENV=production).
BILLING_TEST=true
