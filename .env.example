# Shopify App Credentials (from Shopify Partners dashboard)
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SHOPIFY_SCOPES=read_orders

# App URL (your tunnel URL for local dev, or production URL)
HOST=https://your-tunnel-url.trycloudflare.com

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shopify_orders_sync

# Server port
PORT=3001

# Frontend env (must be prefixed with VITE_ to be available in the browser)
VITE_SHOPIFY_API_KEY=your_api_key_here
