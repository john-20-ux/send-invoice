# Ruby app runtime
PORT=3000
BIND_ADDRESS=0.0.0.0
HOST=http://localhost:3000
DATABASE_PATH=ruby_app/db/send_invoice.sqlite3

# Set to true to force demo data mode.
MOCK_MODE=true

# Optional Shopify credentials for real OAuth + sync mode
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_orders
SHOPIFY_API_VERSION=2026-04

# Order webhooks (ORDERS_CREATE/UPDATED/EDITED) carry protected customer data and
# require approved Protected Customer Data access in the Partner Dashboard. Leave
# false until that access is granted; scheduled bulk sync covers orders meanwhile.
ENABLE_ORDER_WEBHOOKS=false

# Optional automated sync
AUTO_SYNC_ENABLED=false
AUTO_SYNC_INTERVAL_SECONDS=300
SYNC_API_SECRET=
