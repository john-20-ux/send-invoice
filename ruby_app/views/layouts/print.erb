<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title><%= h(@page_title || "Printable Invoice") %></title>
    <link rel="stylesheet" href="/assets/app.css">
  </head>
  <body class="print-body">
    <div class="print-toolbar">
      <a href="/vendors" class="button button-ghost">Back to vendors</a>
      <button type="button" class="button" onclick="window.print()">Print or Save PDF</button>
    </div>
    <main class="print-sheet">
      <%= @content %>
    </main>
  </body>
</html>
