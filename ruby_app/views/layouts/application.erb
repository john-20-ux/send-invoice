<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title><%= h(@page_title || "Send Invoice") %></title>
    <link rel="stylesheet" href="/assets/app.css?v=28">
    <script>try{if(localStorage.getItem("si-nav-rail")==="1")document.documentElement.classList.add("nav-rail")}catch(e){}</script>
  </head>
  <body class="app-body">
    <div class="page-noise"></div>
    <% if @shop && @shop["onboarded"] %>
      <div class="app-frame">
        <aside class="sidebar">
          <button type="button" class="sidebar-toggle" data-action="toggle-nav-rail" aria-label="Toggle sidebar" title="Collapse sidebar">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="4" width="18" height="16" rx="2"></rect><path d="M9 4v16"></path>
            </svg>
          </button>
          <a href="/dashboard" class="brand">
            <span class="brand-mark">SI</span>
            <span class="brand-text">
              <strong>Send Invoice</strong>
              <small>Orders and payouts</small>
            </span>
          </a>
          <nav class="nav-stack">
            <% @nav_items.each do |item| %>
              <a href="<%= item["path"] %>" class="nav-link <%= active_path?(@current_path, item["path"]) ? "is-active" : "" %>" aria-label="<%= h(item["label"]) %>" title="<%= h(item["label"]) %>">
                <%= nav_icon(item["path"]) %>
                <span class="nav-label"><%= h(item["label"]) %></span>
              </a>
            <% end %>
          </nav>
          <% if @admin_nav_items && !@admin_nav_items.empty? %>
            <p class="eyebrow">Admin</p>
            <nav class="nav-stack">
              <% @admin_nav_items.each do |item| %>
                <a href="<%= item["path"] %>" class="nav-link <%= active_path?(@current_path, item["path"]) ? "is-active" : "" %>" aria-label="<%= h(item["label"]) %>" title="<%= h(item["label"]) %>">
                  <%= nav_icon(item["path"]) %>
                  <span class="nav-label"><%= h(item["label"]) %></span>
                </a>
              <% end %>
            </nav>
          <% end %>
          <div class="sidebar-footnote">
            <p><strong><%= h(@shop["shop_name"] || @shop["shop_domain"]) %></strong></p>
            <p><%= h(@shop["shop_domain"]) %></p>
          </div>
        </aside>

        <main class="workspace">
          <%= render_partial("trial_banner", shop: @shop) %>
          <% if @reauth_required %>
            <div class="reauth-banner">
              <span>This app needs additional permissions to keep working. Please reauthorize.</span>
              <a class="button" href="<%= h(@reauth_path) %>">Reauthorize</a>
            </div>
          <% end %>
          <% if @current_path == "/dashboard" || @current_path.to_s.start_with?("/orders") %>
            <%= render_partial("sync_banner", shop: @shop, sync_status: @sync_status) %>
          <% end %>

          <% if @flash %>
            <div class="<%= flash_class(@flash["type"]) %>">
              <span><%= h(@flash["message"]) %></span>
            </div>
          <% end %>

          <section class="page-content">
            <%= @content %>
          </section>
        </main>
      </div>
    <% else %>
      <main class="public-shell">
        <header class="public-brand">
          <a href="/" class="brand">
            <span class="brand-mark">SI</span>
            <span>
              <strong>Send Invoice</strong>
              <small>Orders and payouts</small>
            </span>
          </a>
        </header>

        <% if @flash %>
          <div class="<%= flash_class(@flash["type"]) %>">
            <span><%= h(@flash["message"]) %></span>
          </div>
        <% end %>

        <section class="public-content">
          <%= @content %>
        </section>
      </main>
    <% end %>

    <script src="/assets/app.js?v=28"></script>
  </body>
</html>
