<% if @shop && @shop["current_plan"] == "trial" %>
  <% elapsed = ((Time.now - Time.parse(@shop["trial_started_at"])) / 86_400).floor %>
  <% remaining = [14 - elapsed, 0].max %>
  <div class="trial-banner">
    <span>Your free trial expires in <strong><%= remaining %></strong> day<%= remaining == 1 ? "" : "s" %>.</span>
    <a href="/settings/plans">Upgrade now</a>
  </div>
<% end %>
