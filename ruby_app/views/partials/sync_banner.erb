<% sync_active = %w[running queued failed].include?(@sync_status["status"]) %>
<% # Only surface the banner while a sync is active or failed. Once it has
   # settled (completed/idle), hide it for merchants; admins keep it so the
   # background-request recovery tools stay reachable. %>
<% hidden = !sync_active && !@queue_ops_admin %>
<% progress = percentage(@sync_status["ordersSynced"], @sync_status["totalEstimated"]) %>
<% sync_error = @sync_status["errorMessage"].to_s %>
<% protected_access_blocked = sync_error.match?(/not approved to access the Order object|not approved to subscribe to webhook topics containing protected customer data/i) %>
<div
  id="sync-banner"
  class="sync-banner <%= "is-hidden" if hidden %>"
  data-api-path="/api/sync/status"
  data-async-enabled="<%= @queue_ops_admin ? "true" : "false" %>"
  data-async-requests-path="<%= @queue_ops_admin ? "/api/async-requests?status=failed&limit=5" : "" %>"
  data-async-retry-latest-path="<%= @queue_ops_admin ? "/api/async-requests/retry-latest-failed" : "" %>"
  data-async-retry-all-path="<%= @queue_ops_admin ? "/api/async-requests/retry-all-failed" : "" %>"
  data-shop-domain="<%= h(@shop && @shop["shop_domain"]) %>"
  data-status="<%= h(@sync_status["status"]) %>"
  data-orders-synced="<%= @sync_status["ordersSynced"] %>"
  data-total-estimated="<%= @sync_status["totalEstimated"] %>"
  data-last-synced-at="<%= h(@sync_status["lastSyncedAt"]) %>"
  data-queued-at="<%= h(@sync_status["queuedAt"]) %>"
>
  <div class="sync-copy">
    <strong data-role="status-label">
      <% if @sync_status["status"] == "running" %>
        Syncing orders
      <% elsif @sync_status["status"] == "queued" %>
        Sync queued
      <% elsif @sync_status["status"] == "failed" %>
        Sync failed
      <% elsif @sync_status["lastSyncedAt"] %>
        Last synced <%= time_ago(@sync_status["lastSyncedAt"]) %>
      <% else %>
        Sync idle
      <% end %>
    </strong>
    <span data-role="status-meta">
      <% if @sync_status["status"] == "running" %>
        <%= @sync_status["ordersSynced"] %> of <%= @sync_status["totalEstimated"] %> orders synced
      <% elsif @sync_status["status"] == "queued" %>
        Waiting for the background worker to start this sync.
      <% elsif @sync_status["status"] == "failed" %>
        The latest sync did not complete.
      <% else %>
        Shopify data is ready.
      <% end %>
    </span>
  </div>
  <div class="sync-progress">
    <span data-role="progress-bar" style="width:<%= progress %>%"></span>
  </div>
  <span class="sync-progress-value" data-role="progress-value"><%= progress %>%</span>
  <div class="sync-banner-actions">
    <form method="post" action="/orders/sync">
      <button class="button" type="submit" <% if @sync_status["status"] == "running" %>disabled<% end %>>
        <%= @sync_status["status"] == "running" ? "Syncing..." : "Sync now" %>
      </button>
    </form>
  </div>
  <% if protected_access_blocked %>
    <p class="sync-banner-note">
      Auto sync is blocked until Shopify approves protected customer data access for this app.
    </p>
  <% end %>
  <% if @queue_ops_admin %>
    <div class="sync-recovery-panel is-hidden" data-role="async-request-panel">
      <div class="sync-recovery-header">
        <div class="sync-recovery-summary">
          <strong>Failed background requests</strong>
          <span class="sync-recovery-count" data-role="async-request-count">0 requests</span>
        </div>
        <div class="sync-recovery-tools">
          <button type="button" class="sync-request-button" data-action="retry-latest-failed">Retry latest failed</button>
          <button type="button" class="sync-request-button" data-action="retry-all-failed">Retry all failed</button>
        </div>
      </div>
      <div class="sync-recovery-list" data-role="async-request-list"></div>
      <p class="sync-recovery-empty is-hidden" data-role="async-request-empty">No failed background requests remain for this shop.</p>
    </div>
  <% end %>
</div>
