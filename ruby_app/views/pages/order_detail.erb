<% raw = @selected_order["raw_data"].is_a?(Hash) ? @selected_order["raw_data"] : {} %>
<% subtotal = @selected_order["line_items"].sum { |line_item| line_item["totalAmount"].to_f } %>
<% item_quantity = @selected_order["line_items"].sum { |line_item| line_item["quantity"].to_i } %>
<% customer_name = [@selected_order["customer_first_name"], @selected_order["customer_last_name"]].compact.join(" ").strip %>
<% shipping_lines = address_lines(raw["shippingAddress"] || {}) %>
<% billing_lines = address_lines(raw["billingAddress"] || {}) %>
<% customer_lines = address_lines(raw["customer"] || {}) %>
<% tags = raw["tags"].is_a?(Array) ? raw["tags"].reject { |tag| tag.to_s.strip.empty? } : [] %>
<% transaction_rows = if raw["transactions"].is_a?(Array) && !raw["transactions"].empty?
    raw["transactions"]
  else
    Array(@selected_order["transactions"]).map do |transaction|
      {
        "kind" => "PAYMENT",
        "status" => @selected_order["financial_status"],
        "gateway" => "Synced transaction",
        "processedAt" => @selected_order["updated_at"],
        "amountSet" => {
          "shopMoney" => {
            "amount" => transaction["amount"],
            "currencyCode" => transaction["currency"] || @selected_order["total_price_currency"]
          }
        }
      }
    end
  end %>

<section class="detail-panel order-detail-shell">
  <div class="toolbar">
    <div>
      <a class="back-link" href="<%= h(@order_back_path) %>">
        <svg viewBox="0 0 16 16" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M10 3 5 8l5 5"></path>
        </svg>
        Back to orders
      </a>
      <p class="eyebrow">Shopify order</p>
      <h2><%= h(@selected_order["name"]) %></h2>
      <p class="section-note"><%= h(@selected_order["id"]) %></p>
    </div>
    <div class="button-inline">
      <a class="button-ghost" href="<%= order_invoice_path(@selected_order["id"], @shop["shop_domain"]) %>" target="_blank" rel="noreferrer">Preview invoice</a>
      <a class="button-ghost" href="<%= order_invoice_pdf_path(@selected_order["id"], @shop["shop_domain"]) %>">Download PDF</a>
      <span class="<%= badge_class(@selected_order["financial_status"]) %>"><%= h(@selected_order["financial_status"]) %></span>
      <span class="<%= badge_class(@selected_order["fulfillment_status"] || "UNFULFILLED") %>"><%= h(@selected_order["fulfillment_status"] || "UNFULFILLED") %></span>
    </div>
  </div>

  <div class="grid-four order-summary-grid">
    <article class="metric-card">
      <p class="label">Customer</p>
      <p class="value"><%= h(customer_name.empty? ? "Guest" : customer_name) %></p>
    </article>
    <article class="metric-card">
      <p class="label">Items</p>
      <p class="value"><%= item_quantity %></p>
    </article>
    <article class="metric-card">
      <p class="label">Order total</p>
      <p class="value"><%= format_money(@selected_order["total_price_amount"], @selected_order["total_price_currency"]) %></p>
    </article>
    <article class="metric-card">
      <p class="label">Last synced</p>
      <p class="value"><%= time_ago(@selected_order["synced_at"]) %></p>
    </article>
  </div>

  <div class="order-workspace">
    <div class="order-main-column">
      <section class="section-card">
        <div class="toolbar">
          <div>
            <p class="eyebrow">Invoice delivery</p>
            <h3>Send invoice</h3>
            <p class="section-note">
              <% if @invoice_delivery_mode == "smtp" %>
                Direct email delivery is enabled through SMTP.
              <% else %>
                Direct SMTP is not configured yet. Sent invoices are saved to the local outbox.
              <% end %>
            </p>
          </div>
        </div>

        <form method="post" action="<%= order_send_invoice_path(@selected_order["id"], @shop["shop_domain"]) %>" class="stack" style="margin-top:20px">
          <div class="grid-two">
            <div class="field">
              <label for="recipient_email">Recipient email</label>
              <input id="recipient_email" name="recipient_email" type="email" value="<%= h(@selected_order_invoice_draft["recipient_email"]) %>" required>
            </div>
            <div class="field">
              <label>Invoice file</label>
              <input type="text" value="<%= h(@selected_order_invoice_filename) %>" disabled>
            </div>
          </div>
          <div class="field">
            <label for="email_subject">Subject</label>
            <input id="email_subject" name="email_subject" type="text" value="<%= h(@selected_order_invoice_draft["subject"]) %>">
          </div>
          <div class="field">
            <label for="email_body">Message</label>
            <textarea id="email_body" name="email_body" rows="8"><%= h(@selected_order_invoice_draft["body_text"]) %></textarea>
          </div>
          <div class="button-inline">
            <button class="button" type="submit">Send invoice</button>
          </div>
        </form>
      </section>

      <section class="table-shell">
        <div class="toolbar">
          <div>
            <p class="eyebrow">Line items</p>
            <h3>Items in this order</h3>
          </div>
        </div>
        <table class="data-table">
          <thead>
            <tr>
              <th>Item</th>
              <th>SKU</th>
              <th>Vendor</th>
              <th class="align-right">Qty</th>
              <th class="align-right">Current Qty</th>
              <th class="align-right">Line total</th>
            </tr>
          </thead>
          <tbody>
            <% @selected_order["line_items"].each do |line_item| %>
              <tr>
                <td>
                  <strong><%= h(line_item["title"]) %></strong>
                  <div class="table-subcopy"><%= h(line_item["variantTitle"] || "Default variant") %></div>
                </td>
                <td><%= h(line_item["sku"] || "-") %></td>
                <td><%= h(line_item["vendor"] || "-") %></td>
                <td class="align-right"><%= line_item["quantity"] %></td>
                <td class="align-right"><%= line_item["currentQuantity"] %></td>
                <td class="align-right"><%= format_money(line_item["totalAmount"], line_item["totalCurrency"]) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </section>

      <section class="table-shell">
        <div class="toolbar">
          <div>
            <p class="eyebrow">Payments</p>
            <h3>Transactions</h3>
          </div>
        </div>
        <table class="data-table">
          <thead>
            <tr>
              <th>Transaction</th>
              <th>Status</th>
              <th>Gateway</th>
              <th>Processed</th>
              <th class="align-right">Amount</th>
            </tr>
          </thead>
          <tbody>
            <% transaction_rows.each do |transaction| %>
              <% amount = transaction.dig("amountSet", "shopMoney", "amount") || transaction["amount"] %>
              <% currency = transaction.dig("amountSet", "shopMoney", "currencyCode") || transaction["currency"] || @selected_order["total_price_currency"] %>
              <tr>
                <td><strong><%= h((transaction["kind"] || "Payment").to_s.tr("_", " ")) %></strong></td>
                <td><span class="<%= badge_class(transaction["status"] || @selected_order["financial_status"]) %>"><%= h(transaction["status"] || @selected_order["financial_status"]) %></span></td>
                <td><%= h(transaction["gateway"] || "Shopify") %></td>
                <td><%= format_datetime(transaction["processedAt"] || @selected_order["updated_at"]) %></td>
                <td class="align-right"><%= format_money(amount, currency) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </section>

      <section class="section-card">
        <div class="toolbar">
          <div>
            <p class="eyebrow">Delivery history</p>
            <h3>Recent invoice attempts</h3>
          </div>
        </div>
        <% if @selected_order_invoice_deliveries.empty? %>
          <div class="empty-state">No invoice has been sent for this order yet.</div>
        <% else %>
          <table class="data-table">
            <thead>
              <tr>
                <th>When</th>
                <th>Recipient</th>
                <th>Status</th>
                <th>Channel</th>
                <th>File</th>
                <th>Details</th>
              </tr>
            </thead>
            <tbody>
              <% @selected_order_invoice_deliveries.each do |delivery| %>
                <tr>
                  <td><%= format_datetime(delivery["created_at"]) %></td>
                  <td><%= h(delivery["recipient_email"]) %></td>
                  <td><span class="<%= badge_class(delivery["delivery_status"]) %>"><%= h(delivery["delivery_status"]) %></span></td>
                  <td><%= h(delivery["delivery_channel"]) %></td>
                  <td><%= h(delivery["invoice_filename"]) %></td>
                  <td>
                    <% if delivery["error_message"] %>
                      <span class="muted"><%= h(delivery["error_message"]) %></span>
                    <% elsif delivery["outbox_path"] %>
                      <span class="muted"><%= h(delivery["outbox_path"]) %></span>
                    <% else %>
                      <span class="muted"><%= h(delivery["delivery_target"] || "-") %></span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% end %>
      </section>
    </div>

    <aside class="order-side-column">
      <section class="preview-card order-info-card">
        <h3>Summary</h3>
        <dl class="order-facts">
          <div class="order-facts-row"><dt>Created</dt><dd><%= format_datetime(@selected_order["created_at"]) %></dd></div>
          <div class="order-facts-row"><dt>Updated</dt><dd><%= format_datetime(@selected_order["updated_at"]) %></dd></div>
          <div class="order-facts-row"><dt>Subtotal</dt><dd><%= format_money(subtotal, @selected_order["total_price_currency"]) %></dd></div>
          <div class="order-facts-row"><dt>Discounts</dt><dd><%= format_money(-@selected_order["total_discounts_amount"], @selected_order["total_price_currency"]) %></dd></div>
          <div class="order-facts-row"><dt>Shipping</dt><dd><%= format_money(@selected_order["total_shipping_amount"], @selected_order["total_price_currency"]) %></dd></div>
          <div class="order-facts-row"><dt>Tax</dt><dd><%= format_money(@selected_order["total_tax_amount"], @selected_order["total_price_currency"]) %></dd></div>
          <div class="order-facts-row"><dt>Refunded</dt><dd><%= format_money(@selected_order["total_refunded_amount"], @selected_order["total_price_currency"]) %></dd></div>
          <div class="order-facts-row"><dt>Weight</dt><dd><%= format_weight(@selected_order["total_weight"]) %></dd></div>
        </dl>
      </section>

      <section class="preview-card order-info-card">
        <h3>Customer</h3>
        <dl class="order-facts">
          <div class="order-facts-row"><dt>Name</dt><dd><%= h(customer_name.empty? ? "Guest" : customer_name) %></dd></div>
          <div class="order-facts-row"><dt>Email</dt><dd><%= h(@selected_order["customer_email"] || "No email") %></dd></div>
          <div class="order-facts-row"><dt>Phone</dt><dd><%= h(@selected_order["customer_phone"] || "No phone") %></dd></div>
          <div class="order-facts-row"><dt>Customer ID</dt><dd><%= h(@selected_order["customer_id"] || "-") %></dd></div>
        </dl>
        <% if customer_lines.any? %>
          <div class="order-address-block">
            <% customer_lines.each do |line| %><p><%= h(line) %></p><% end %>
          </div>
        <% end %>
      </section>

      <section class="preview-card order-info-card">
        <h3>Shipping</h3>
        <% if shipping_lines.any? %>
          <div class="order-address-block">
            <% shipping_lines.each do |line| %><p><%= h(line) %></p><% end %>
          </div>
        <% else %>
          <p class="muted">No shipping address was synced for this order.</p>
        <% end %>
      </section>

      <section class="preview-card order-info-card">
        <h3>Billing and notes</h3>
        <% if billing_lines.any? %>
          <div class="order-address-block">
            <% billing_lines.each do |line| %><p><%= h(line) %></p><% end %>
          </div>
        <% else %>
          <p class="muted">No billing address was synced for this order.</p>
        <% end %>

        <% if raw["note"].to_s.strip != "" %>
          <div class="order-note">
            <strong>Note</strong>
            <p><%= h(raw["note"]) %></p>
          </div>
        <% end %>

        <% if tags.any? %>
          <div class="order-tag-row">
            <% tags.each do |tag| %><span class="pill pill-muted"><%= h(tag) %></span><% end %>
          </div>
        <% end %>
      </section>
    </aside>
  </div>
</section>
