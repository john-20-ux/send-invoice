<section class="section-card">
  <h2>Invoice defaults</h2>
  <p class="section-note">Default tax, currency, and invoice typography.</p>

  <form method="post" action="/settings" class="grid-three" style="margin-top:20px">
    <div class="field">
      <label for="tax_rate">Tax rate (%)</label>
      <input id="tax_rate" name="tax_rate" type="number" step="0.5" min="0" max="100" value="<%= @shop["tax_rate"] %>">
    </div>
    <div class="field">
      <label for="currency">Default currency</label>
      <select id="currency" name="currency">
        <% ["USD ($)", "EUR (EUR)", "GBP (GBP)", "INR (INR)"].each do |currency| %>
          <option value="<%= currency %>" <%= @shop["currency"] == currency ? "selected" : "" %>><%= currency %></option>
        <% end %>
      </select>
    </div>
    <div class="field">
      <label for="font_name">Font style</label>
      <select id="font_name" name="font_name">
        <% ["Avenir Next", "Georgia", "Palatino", "Courier New"].each do |font| %>
          <option value="<%= font %>" <%= @shop["font_name"] == font ? "selected" : "" %>><%= font %></option>
        <% end %>
      </select>
    </div>
    <div class="button-inline">
      <button class="button" type="submit">Save settings</button>
    </div>
  </form>
</section>

<div class="grid-two">
  <section class="section-card">
    <h2>Invoice sending</h2>
    <p class="section-note">
      <% if @invoice_delivery_mode == "smtp" %>
        SMTP delivery is active for order invoice sends.
      <% else %>
        Order invoice sends currently use the local outbox fallback until SMTP is configured.
      <% end %>
    </p>
    <div class="button-inline" style="margin-top:18px">
      <a class="button-secondary" href="/notifications">Manage email template</a>
    </div>
  </section>

  <section class="section-card">
    <h2>Notifications</h2>
    <p class="section-note">Configure email, WhatsApp, Slack, and Basecamp delivery rules.</p>
    <div class="button-inline" style="margin-top:18px">
      <a class="button-secondary" href="/notifications">Manage notifications</a>
    </div>
  </section>

  <section class="section-card">
    <h2>Plan and trial</h2>
    <p class="section-note">You are currently on the <strong><%= h(@shop["current_plan"].capitalize) %></strong> plan.</p>
    <div class="button-inline" style="margin-top:18px">
      <a class="button-secondary" href="/settings/plans">View plans</a>
    </div>
  </section>

  <section class="section-card">
    <h2>Policies</h2>
    <p class="section-note">Use these public pages for app review, merchant trust, and support references.</p>
    <div class="button-inline" style="margin-top:18px">
      <a class="button-secondary" href="/legal/privacy" target="_blank" rel="noreferrer">Privacy policy</a>
      <a class="button-secondary" href="/legal/terms" target="_blank" rel="noreferrer">Terms of service</a>
    </div>
  </section>
</div>
