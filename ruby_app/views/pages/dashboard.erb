<div class="grid-four">
  <article class="metric-card">
    <p class="label">Total orders</p>
    <p class="value"><%= @stats["total_orders"] %></p>
  </article>
  <article class="metric-card">
    <p class="label">Total revenue</p>
    <p class="value"><%= format_money(@stats["total_revenue"], "USD") %></p>
  </article>
  <article class="metric-card">
    <p class="label">Paid orders</p>
    <p class="value"><%= @stats["paid_orders"] %></p>
  </article>
  <article class="metric-card">
    <p class="label">Fulfilled</p>
    <p class="value"><%= @stats["fulfilled"] %></p>
  </article>
</div>

<div class="grid-two">
  <section class="section-card">
    <p class="eyebrow">Last 30 days</p>
    <h2>Daily revenue</h2>
    <p class="section-note">Recent order value by creation date.</p>
    <div class="chart-bars compact">
      <% @daily_points.last(15).each do |point| %>
        <% height = ((point["revenue"] / @max_daily_revenue.to_f) * 100).round %>
        <div class="chart-column">
          <div class="chart-value"><%= format_money(point["revenue"], "USD") %></div>
          <div class="chart-bar" style="height:<%= [height, 6].max %>%"></div>
          <div class="chart-caption"><%= point["date"][5..9] %></div>
        </div>
      <% end %>
    </div>
  </section>

  <section class="section-card">
    <p class="eyebrow">Financial status</p>
    <h2>Order mix</h2>
    <p class="section-note">Current payment state across imported orders.</p>
    <% max_count = [@status_points.map { |item| item["count"] }.max.to_i, 1].max %>
    <div class="status-list">
      <% @status_points.each do |item| %>
        <% width = ((item["count"].to_f / max_count) * 100).round %>
        <div class="status-row">
          <span><%= h(item["status"]) %></span>
          <div class="meter"><span style="width:<%= width %>%"></span></div>
          <strong><%= item["count"] %></strong>
        </div>
      <% end %>
    </div>
  </section>
</div>

<section class="section-card">
  <div class="topbar" style="margin:0 0 8px">
    <div>
      <p class="eyebrow">Invoice automation</p>
      <h2>Automation &amp; deliveries</h2>
      <p class="section-note">Automated invoice sending status and recent delivery health.</p>
    </div>
    <div class="button-inline">
      <a class="button-secondary" href="<%= query_path("/automations", { "shop" => @shop["shop_domain"] }) %>">Automations</a>
      <a class="button-secondary" href="<%= query_path("/delivery-log", { "shop" => @shop["shop_domain"] }) %>">Delivery log</a>
    </div>
  </div>
  <div class="grid-four">
    <article class="metric-card">
      <p class="label">Automation</p>
      <p class="value"><%= @automation_enabled ? "On" : "Off" %></p>
    </article>
    <article class="metric-card">
      <p class="label">Active rules</p>
      <p class="value"><%= @automation_active_rules %></p>
    </article>
    <article class="metric-card">
      <p class="label">Failed sends (7d)</p>
      <p class="value"><%= @automation_delivery_summary["failed"] %></p>
    </article>
    <article class="metric-card">
      <p class="label">Overdue unpaid</p>
      <p class="value"><%= @automation_overdue %></p>
    </article>
  </div>
</section>
