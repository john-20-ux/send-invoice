<% if @selected_order_missing %>
  <section class="section-card order-missing-state">
    <div class="toolbar">
      <div>
        <p class="eyebrow">Order detail</p>
        <h2>Order not found</h2>
        <p class="section-note">We could not find that order in the synced data for this shop.</p>
      </div>
      <a class="button-ghost" href="/orders">Back to orders</a>
    </div>
  </section>
<% end %>

<section class="section-card">
  <div class="toolbar">
    <div>
      <h2>Orders</h2>
      <p class="section-note"><%= @order_result["total"] %> orders match the current filters.</p>
    </div>
    <form method="post" action="/orders/sync">
      <button class="button" type="submit">Sync</button>
    </form>
  </div>

  <form method="get" action="/orders" class="orders-filters" style="margin-top:20px">
    <div class="field">
      <label for="search">Search</label>
      <input id="search" type="text" name="search" value="<%= h(@filters[:search]) %>" placeholder="Name, order, email">
    </div>
    <div class="field" data-date-range>
      <label>Date range</label>
      <div class="date-range-native">
        <input id="from" type="date" name="from" value="<%= h(@filters[:from]) %>" aria-label="From date">
        <span class="date-range-native-sep">to</span>
        <input id="to" type="date" name="to" value="<%= h(@filters[:to]) %>" aria-label="To date">
      </div>
    </div>
    <div class="field">
      <label for="financial_status">Payment status</label>
      <select id="financial_status" name="financial_status">
        <option value="">All payments</option>
        <% @status_options["financial"].each do |status| %>
          <option value="<%= h(status) %>" <%= "selected" if @filters[:financial_status] == status %>><%= h(humanize_status(status)) %></option>
        <% end %>
      </select>
    </div>
    <div class="field">
      <label for="fulfillment_status">Fulfillment status</label>
      <select id="fulfillment_status" name="fulfillment_status">
        <option value="">All fulfillment</option>
        <% @status_options["fulfillment"].each do |status| %>
          <option value="<%= h(status) %>" <%= "selected" if @filters[:fulfillment_status] == status %>><%= h(humanize_status(status)) %></option>
        <% end %>
      </select>
    </div>
    <div class="button-inline filter-actions">
      <button class="button" type="submit">Apply</button>
      <a class="button-ghost" href="/orders">Clear</a>
    </div>
  </form>
</section>

<section class="table-shell">
  <% if @order_result["orders"].empty? %>
    <div class="empty-state">No orders match your filters.</div>
  <% else %>
    <table class="data-table">
      <thead>
        <tr>
          <th>Order</th>
          <th>Date</th>
          <th>Customer</th>
          <th>Email</th>
          <th class="align-right">Items</th>
          <th class="align-right">Total</th>
          <th>Payment</th>
          <th>Fulfillment</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @order_result["orders"].each do |order| %>
          <tr class="order-row" data-href="<%= order_detail_path(order["id"], @shop["shop_domain"]) %>">
            <td><a class="order-link" href="<%= order_detail_path(order["id"], @shop["shop_domain"]) %>"><strong><%= h(order["name"]) %></strong></a></td>
            <td><%= format_date(order["created_at"]) %></td>
            <td><%= h("#{order["customer_first_name"]} #{order["customer_last_name"]}".strip) %></td>
            <td><%= h(order["customer_email"] || "-") %></td>
            <td class="align-right"><%= order["line_items"].length %></td>
            <td class="align-right"><%= format_money(order["total_price_amount"], order["total_price_currency"]) %></td>
            <td><span class="<%= badge_class(order["financial_status"]) %>"><%= h(order["financial_status"]) %></span></td>
            <td><span class="<%= badge_class(order["fulfillment_status"] || "UNFULFILLED") %>"><%= h(order["fulfillment_status"] || "UNFULFILLED") %></span></td>
            <td>
              <div class="row-actions">
                <a class="button-ghost" href="<%= order_invoice_path(order["id"], @shop["shop_domain"]) %>" target="_blank" rel="noreferrer">Invoice</a>
                <a class="button-ghost" href="<%= order_invoice_pdf_path(order["id"], @shop["shop_domain"]) %>">PDF</a>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</section>

<% if @order_result["total_pages"] > 1 %>
  <section class="section-card pagination">
    <span>Page <%= @order_result["page"] %> of <%= @order_result["total_pages"] %></span>
    <div class="pagination-links">
      <% if @order_result["page"] > 1 %>
        <a class="button-ghost" href="<%= query_path(@pagination_path, {
          "search" => @filters[:search],
          "from" => @filters[:from],
          "to" => @filters[:to],
          "financial_status" => @filters[:financial_status],
          "fulfillment_status" => @filters[:fulfillment_status],
          "page" => @order_result["page"] - 1
        }) %>">Previous</a>
      <% end %>
      <% if @order_result["page"] < @order_result["total_pages"] %>
        <a class="button-ghost" href="<%= query_path(@pagination_path, {
          "search" => @filters[:search],
          "from" => @filters[:from],
          "to" => @filters[:to],
          "financial_status" => @filters[:financial_status],
          "fulfillment_status" => @filters[:fulfillment_status],
          "page" => @order_result["page"] + 1
        }) %>">Next</a>
      <% end %>
    </div>
  </section>
<% end %>
