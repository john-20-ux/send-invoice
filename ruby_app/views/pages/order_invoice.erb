<% document = @invoice_document %>
<section
  class="template-preview"
  data-template="<%= h(document["template"]) %>"
  data-density="<%= h(document["density"]) %>"
  data-header-align="<%= h(document["header_align"]) %>"
  data-surface-tone="<%= h(document["surface_tone"]) %>"
  style="--invoice-accent:<%= h(document["accent_color"]) %>;--invoice-font:<%= h(document["font_family"]) %>;"
>
  <header class="preview-header">
    <div class="preview-branding">
      <div class="preview-logo-mark"><%= h(document["logo_text"]) %></div>
      <div>
        <span class="preview-style-badge"><%= h(document["template"].to_s.capitalize) %></span>
        <h2><%= h(document["company_name"]) %></h2>
        <p class="muted"><%= h(document["tagline"]) %></p>
      </div>
    </div>
    <div class="preview-meta">
      <span><strong><%= h(document["invoice_number"]) %></strong></span>
      <span><%= h(document["invoice_date"]) %></span>
      <span><%= h(document["due_date"]) %></span>
    </div>
  </header>

  <section class="preview-parties">
    <div>
      <p class="eyebrow">From</p>
      <p><%= h(document["company_name"]) %></p>
      <p><%= h(document["address"]) %></p>
      <p><%= h(document["phone"]) %></p>
      <p><%= h(document["email"]) %></p>
      <% if document.dig("visible_fields", "website") %><p><%= h(document["website"]) %></p><% end %>
      <% if document.dig("visible_fields", "gst") %><p><%= h(document["gst"]) %></p><% end %>
    </div>
    <div>
      <p class="eyebrow">Bill to</p>
      <p><%= h(document["bill_to"]) %></p>
      <% document["client_address"].to_s.split("\n").reject(&:empty?).each do |line| %>
        <p><%= h(line) %></p>
      <% end %>
      <% unless document["client_email"].to_s.empty? %><p><%= h(document["client_email"]) %></p><% end %>
      <% unless document["payment_terms"].to_s.empty? %><p class="muted" style="margin-top:8px"><%= h(document["payment_terms"]) %></p><% end %>
    </div>
  </section>

  <table class="preview-lines">
    <thead>
      <tr>
        <th>Description</th>
        <th class="align-right">Qty</th>
        <th class="align-right">Rate</th>
        <th class="align-right">Amount</th>
      </tr>
    </thead>
    <tbody>
      <% document["line_items"].each do |line_item| %>
        <tr>
          <td>
            <strong><%= h(line_item["desc"]) %></strong>
            <% unless line_item["variant"].to_s.empty? %><div class="muted"><%= h(line_item["variant"]) %></div><% end %>
          </td>
          <td class="align-right"><%= line_item["qty"] %></td>
          <td class="align-right"><%= document["currency_symbol"] %><%= format('%.2f', line_item["rate"]) %></td>
          <td class="align-right"><%= document["currency_symbol"] %><%= format('%.2f', line_item["total"]) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="preview-footer">
    <div>
      <% if document.dig("visible_fields", "notes") %><p class="muted"><%= h(document["notes"]) %></p><% end %>
      <% if document.dig("visible_fields", "bank_details") %><p class="muted" style="margin-top:8px"><%= h(document["bank_details"]) %></p><% end %>
      <% if document.dig("visible_fields", "terms") %><p class="muted" style="margin-top:8px"><%= h(document["terms"]) %></p><% end %>
    </div>
    <div class="preview-totals">
      <div><span>Subtotal</span><strong><%= document["currency_symbol"] %><%= format('%.2f', document["subtotal_amount"]) %></strong></div>
      <div><span>Discounts</span><strong><%= document["currency_symbol"] %><%= format('%.2f', document["discounts_amount"]) %></strong></div>
      <div><span>Shipping</span><strong><%= document["currency_symbol"] %><%= format('%.2f', document["shipping_amount"]) %></strong></div>
      <div><span>Tax</span><strong><%= document["currency_symbol"] %><%= format('%.2f', document["tax_amount"]) %></strong></div>
      <div class="preview-total-line"><span>Total</span><strong><%= document["currency_symbol"] %><%= format('%.2f', document["total_amount"]) %></strong></div>
    </div>
  </div>
</section>
