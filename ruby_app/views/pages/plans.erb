<section class="section-card">
  <h2>Plans &amp; billing</h2>
  <% if @plan_status == "active" && @active_plan %>
    <p class="section-note">
      You're on the <strong><%= h(@active_plan.capitalize) %></strong> plan.
      <% if @invoice_limit %>
        Used <strong><%= @invoice_usage %></strong> of <strong><%= @invoice_limit %></strong> invoices this month.
      <% else %>
        Unlimited invoice exports.
      <% end %>
    </p>
  <% elsif @trial_active %>
    <p class="section-note">
      You're on a free trial — <strong><%= @trial_days_remaining %></strong>
      day<%= @trial_days_remaining == 1 ? "" : "s" %> left, all features included.
      Choose a plan to keep going after it ends.
    </p>
  <% else %>
    <p class="section-note">Your free trial has ended. Choose a plan to keep sending invoices.</p>
  <% end %>
</section>

<section class="cards-grid">
  <% @plans.each do |plan| %>
    <% any_active = (@plan_status == "active") %>
    <% active = any_active && @active_plan == plan["id"] %>
    <% recommend = !any_active && plan["popular"] %>
    <% strip = active ? "Your current plan" : (recommend ? "Recommended" : nil) %>
    <article class="section-card plan-card <%= "is-active" if active %><%= " is-recommended" if recommend %>">
      <% if strip %>
        <div class="plan-strip"><%= strip %></div>
      <% elsif plan["popular"] %>
        <p class="eyebrow">Most popular</p>
      <% end %>
      <h2><%= h(plan["name"]) %></h2>
      <p class="muted" style="margin-top:8px"><%= h(plan["tagline"]) %></p>
      <p class="value" style="margin-top:18px"><%= h(plan["price"]) %><small><%= h(plan["period"]) %></small></p>
      <ul class="stack" style="margin-top:18px;padding-left:18px">
        <% plan["features"].each do |feature| %>
          <li><%= h(feature) %></li>
        <% end %>
      </ul>
      <div class="button-inline">
        <% if active %>
          <span class="badge badge-success">Active</span>
        <% else %>
          <form method="post" action="/settings/plans">
            <input type="hidden" name="plan" value="<%= h(plan["id"]) %>">
            <button class="button" type="submit">Choose <%= h(plan["name"]) %></button>
          </form>
        <% end %>
      </div>
    </article>
  <% end %>
</section>
