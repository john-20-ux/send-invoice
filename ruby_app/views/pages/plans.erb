<section class="section-card">
  <h2><%= t("plans.title") %></h2>
  <% if @plan_status == "active" && @active_plan %>
    <% if @invoice_limit %>
      <p class="section-note"><%= t("plans.note.active_metered", plan: @active_plan.capitalize, used: @invoice_usage, limit: @invoice_limit) %></p>
    <% else %>
      <p class="section-note"><%= t("plans.note.active_unlimited", plan: @active_plan.capitalize) %></p>
    <% end %>
  <% elsif @trial_active %>
    <p class="section-note"><%= t("plans.note.trial", count: @trial_days_remaining) %></p>
  <% else %>
    <p class="section-note"><%= t("plans.note.ended") %></p>
  <% end %>
</section>

<section class="cards-grid">
  <% @plans.each do |plan| %>
    <% any_active = (@plan_status == "active") %>
    <% active = any_active && @active_plan == plan["id"] %>
    <% recommend = !any_active && plan["popular"] %>
    <% band_tag = active ? t("plans.tags.current") : (recommend ? t("plans.tags.recommended") : (plan["popular"] ? t("plans.tags.popular") : nil)) %>
    <article class="section-card plan-card <%= "is-active" if active %><%= " is-recommended" if recommend %>">
      <div class="plan-band">
        <span class="plan-name"><%= h(plan["name"]) %></span>
        <% if band_tag %><span class="plan-tag"><%= band_tag %></span><% end %>
      </div>
      <p class="muted plan-tagline"><%= t("plans.tiers.#{plan["id"]}.tagline") %></p>
      <p class="value plan-price"><%= h(plan["price"]) %><small><%= t("plans.per_month") %></small></p>
      <ul class="stack plan-features">
        <% Array(t("plans.tiers.#{plan["id"]}.features")).each do |feature| %>
          <li><%= h(feature) %></li>
        <% end %>
      </ul>
      <div class="button-inline">
        <% if active %>
          <span class="button is-current"><%= t("plans.current_plan") %></span>
        <% else %>
          <form method="post" action="/settings/plans">
            <input type="hidden" name="plan" value="<%= h(plan["id"]) %>">
            <button class="button" type="submit"><%= t("plans.choose", name: plan["name"]) %></button>
          </form>
        <% end %>
      </div>
    </article>
  <% end %>
</section>
