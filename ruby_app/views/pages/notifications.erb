<%
  smtp = @invoice_delivery_mode == "smtp"
  channels = {
    "email" => {
      "title" => "Email", "desc" => "Send invoices and updates by email.",
      "icon" => '<rect x="3" y="5" width="18" height="14" rx="2"></rect><path d="m3 7 9 6 9-6"></path>'
