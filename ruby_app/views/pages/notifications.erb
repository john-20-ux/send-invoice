%>

<form method="post" action="/notifications" class="notif-page">
  <a class="back-link" href="/settings">
    <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 3 5 8l5 5"></path></svg>
    Settings
  </a>
  <div class="settings-head">
    <p class="eyebrow">Settings</p>
    <h1>Notifications</h1>
  </div>

  <div class="notif-content">
    <div class="notif-status">
      <span class="notif-status-ico">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"></rect><path d="m3 7 9 6 9-6"></path></svg>
      </span>
      <div>
        <strong>Email delivery</strong>
        <p><% if smtp %>SMTP is configured — invoices sent from the order detail page go out directly by email.<% else %>SMTP is not configured yet. Invoices sent from the order detail page are saved to the local outbox for review.<% end %></p>
        <div class="ph-label">Supported placeholders</div>
        <div class="ph-chips">
          <% @notification_placeholders.each do |token| %><code class="ph-chip">{{<%= token %>}}</code><% end %>
        </div>
      </div>
    </div>

    <% channels.each do |channel, meta| %>
      <% config = @notification_config[channel] %>
      <section class="notif-card">
        <div class="notif-head">
          <span class="notif-ico <%= "notif-ico--brand" if meta["brand"] %>"><% if meta["brand"] %><%= meta["brand"] %><% else %><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><%= meta["icon"] %></svg><% end %></span>
          <div class="notif-head-text">
            <strong><%= meta["title"] %></strong>
            <p><%= meta["desc"] %></p>
          </div>
          <label class="switch">
            <input id="<%= channel %>_enabled" name="<%= channel %>_enabled" type="checkbox" value="1" <%= config["enabled"] ? "checked" : "" %> aria-label="Enable <%= meta["title"] %>">
            <span class="switch-track"></span>
          </label>
        </div>

        <div class="notif-fields">
          <% if channel == "email" %>
            <div class="field">
              <label for="email_subject">Subject</label>
              <input id="email_subject" name="email_subject" type="text" value="<%= h(config["subject"]) %>">
            </div>
            <div class="field">
              <label for="email_body">Body</label>
              <textarea id="email_body" name="email_body" rows="4"><%= h(config["body"]) %></textarea>
            </div>
          <% elsif channel == "whatsapp" %>
            <div class="notif-connect">
              <% if @whatsapp_configured %>
                <p class="notif-connect-status"><span class="notif-connect-dot" aria-hidden="true"></span>WhatsApp Cloud API is configured.</p>
                <div class="button-inline">
                  <button class="button" type="submit" formaction="/notifications/whatsapp/test" formmethod="post" formnovalidate>Send test message</button>
                </div>
                <p class="notif-connect-note muted">When enabled, a WhatsApp message is sent to the number below each time an invoice is sent from an order.</p>
              <% else %>
                <p class="muted">WhatsApp isn't configured yet. Set <code>WHATSAPP_PHONE_NUMBER_ID</code> and <code>WHATSAPP_ACCESS_TOKEN</code> to enable sending.</p>
              <% end %>
            </div>
            <div class="field">
              <label for="whatsapp_phone">Recipient phone</label>
              <input id="whatsapp_phone" name="whatsapp_phone" type="text" value="<%= h(config["phone"]) %>" placeholder="+1 555 000 1234">
              <small class="field-hint">International format. WhatsApp allows free-form messages only within 24h of the recipient's last message; outside that window Meta requires a pre-approved template.</small>
            </div>
            <div class="field">
              <label for="whatsapp_message">Message</label>
              <textarea id="whatsapp_message" name="whatsapp_message" rows="3"><%= h(config["message"]) %></textarea>
            </div>
          <% elsif channel == "slack" %>
            <% slack_connected = @shop && !@shop["slack_connected_at"].to_s.empty? %>
            <%
              selected_channel = config["channel"].to_s
              # Resolve the saved value (channel ID or "#name") to a display name.
              matched = (@slack_channels || []).find do |c|
                c["id"] == selected_channel ||
                  c["name"].to_s == selected_channel.sub(/\A#/, "")
              end
              display_channel = matched ? "##{matched['name']}" : (@shop && !@shop["slack_channel"].to_s.empty? ? @shop["slack_channel"] : selected_channel)
            %>
            <div class="notif-connect">
              <% if slack_connected %>
                <p class="notif-connect-status">
                  <span class="notif-connect-dot" aria-hidden="true"></span>
                  Connected<% if !@shop["slack_team_name"].to_s.empty? %> to <strong><%= h(@shop["slack_team_name"]) %></strong><% end %><% if !display_channel.to_s.empty? %> · posting to <strong><%= h(display_channel) %></strong><% end %>
                </p>
                <div class="button-inline">
                  <button class="button" type="submit" formaction="/notifications/slack/test" formmethod="post" formnovalidate>Send test alert</button>
                  <button class="button button-ghost" type="submit" formaction="/auth/slack/disconnect" formmethod="post" formnovalidate>Disconnect</button>
                </div>
                <p class="notif-connect-note muted">When enabled, an alert is posted to this channel each time an invoice is sent from an order.</p>
              <% else %>
                <p class="muted">Connect a Slack workspace to post invoice alerts to a channel.</p>
                <a class="button" href="/auth/slack">Connect Slack</a>
              <% end %>
            </div>
            <div class="field">
              <label for="slack_channel">Channel</label>
              <% if @slack_channels && !@slack_channels.empty? %>
                <select id="slack_channel" name="slack_channel">
                  <option value="" disabled <%= "selected" if matched.nil? %>>Select a channel…</option>
                  <% @slack_channels.each do |ch| %>
                    <option value="<%= h(ch["id"]) %>" <%= "selected" if matched && matched["id"] == ch["id"] %>><%= ch["is_private"] ? "🔒 " : "# " %><%= h(ch["name"]) %></option>
                  <% end %>
                </select>
                <small class="field-hint">Channels loaded from your Slack workspace. A private channel appears here only after you invite the app with <code>/invite @YourApp</code>.</small>
              <% else %>
                <input id="slack_channel" name="slack_channel" type="text" value="<%= h(config["channel"]) %>" placeholder="#invoices">
                <small class="field-hint">
                  <% if @slack_channels_error %>Couldn't load channels (<%= h(@slack_channels_error) %>). Add the <code>channels:read</code> and <code>groups:read</code> scopes and reconnect, or enter a channel name/ID manually.<% else %>Public channel name (e.g. #invoices) or a channel ID. For a private channel, invite the app first with <code>/invite @YourApp</code>.<% end %>
                </small>
              <% end %>
            </div>
          <% else %>
            <% basecamp_connected = @shop && !@shop["basecamp_connected_at"].to_s.empty? %>
            <%
              selected_project = config["project_id"].to_s
              matched_project = (@basecamp_projects || []).find { |p| p["id"].to_s == selected_project }
              display_project = matched_project ? matched_project["name"] : config["project_name"].to_s
            %>
            <div class="notif-connect">
              <% if basecamp_connected %>
                <p class="notif-connect-status">
                  <span class="notif-connect-dot" aria-hidden="true"></span>
                  Connected<% if !@shop["basecamp_account_name"].to_s.empty? %> to <strong><%= h(@shop["basecamp_account_name"]) %></strong><% end %><% if !display_project.to_s.empty? %> · posting to <strong><%= h(display_project) %></strong><% end %>
                </p>
                <div class="button-inline">
                  <button class="button" type="submit" formaction="/notifications/basecamp/test" formmethod="post" formnovalidate>Send test update</button>
                  <button class="button button-ghost" type="submit" formaction="/auth/basecamp/disconnect" formmethod="post" formnovalidate>Disconnect</button>
                </div>
                <p class="notif-connect-note muted">When enabled, an update is posted to this project's message board each time an invoice is sent from an order.</p>
              <% elsif @basecamp_configured %>
                <p class="muted">Connect Basecamp to post invoice updates to a project's message board.</p>
                <a class="button" href="/auth/basecamp">Connect Basecamp</a>
              <% else %>
                <p class="muted">Basecamp isn't configured yet. Set <code>BASECAMP_CLIENT_ID</code> and <code>BASECAMP_CLIENT_SECRET</code> to enable connecting.</p>
              <% end %>
            </div>
            <% if basecamp_connected %>
              <div class="field">
                <label for="basecamp_project">Project</label>
                <% if @basecamp_projects && !@basecamp_projects.empty? %>
                  <select id="basecamp_project" name="basecamp_project">
                    <option value="" disabled <%= "selected" if matched_project.nil? %>>Select a project…</option>
                    <% @basecamp_projects.each do |p| %>
                      <option value="<%= h("#{p['id']}:#{p['message_board_id']}:#{p['name']}") %>" <%= "selected" if matched_project && matched_project["id"].to_s == p["id"].to_s %>><%= h(p["name"]) %></option>
                    <% end %>
                  </select>
                  <small class="field-hint">Projects loaded from your Basecamp account. Updates post to the project's Message Board.</small>
                <% else %>
                  <p class="field-hint"><% if @basecamp_projects_error %>Couldn't load projects (<%= h(@basecamp_projects_error) %>).<% else %>No projects with a message board were found in this account.<% end %></p>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>
      </section>
    <% end %>

    <div class="notif-actions">
      <button class="button-primary" type="submit">Save changes</button>
    </div>
  </div>
</form>

<script>
  (function () {
    document.querySelectorAll(".notif-card").forEach(function (card) {
      var input = card.querySelector('input[type="checkbox"]');
      if (!input) return;
      var sync = function () { card.classList.toggle("is-collapsed", !input.checked); };
      sync();
      input.addEventListener("change", sync);
    });
  })();
</script>
