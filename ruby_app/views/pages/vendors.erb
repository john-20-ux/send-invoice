<div class="stack">
  <section class="section-card">
    <div class="toolbar">
      <div>
        <h2>Vendor payouts</h2>
        <p class="section-note">Review revenue, commission, deductions, and net payable by vendor.</p>
      </div>
    </div>
  </section>

  <section class="table-shell">
    <% if @vendor_summaries.empty? %>
      <div class="empty-state">No vendor data is available yet.</div>
    <% else %>
      <table class="data-table">
        <thead>
          <tr>
            <th>Vendor</th>
            <th class="align-right">Orders</th>
            <th class="align-right">Revenue</th>
            <th class="align-right">Commission %</th>
            <th class="align-right">Commission</th>
            <th class="align-right">Deductions</th>
            <th class="align-right">Net payable</th>
            <th>Invoice</th>
          </tr>
        </thead>
        <tbody>
          <% @vendor_summaries.each do |vendor| %>
            <% slug = slugify(vendor["name"]) %>
            <tr>
              <td><strong><%= h(vendor["name"]) %></strong></td>
              <td class="align-right"><%= vendor["total_orders"] %></td>
              <td class="align-right"><%= format_money(vendor["total_revenue"], "USD") %></td>
              <td class="align-right"><%= vendor["commission_rate"] %>%</td>
              <td class="align-right"><%= format_money(vendor["total_commission"], "USD") %></td>
              <td class="align-right"><%= format_money(vendor["custom_deductions"], "USD") %></td>
              <td class="align-right"><strong><%= format_money(vendor["net_payable"], "USD") %></strong></td>
              <td><a class="button-ghost" href="/vendors/<%= slug %>/invoice">Open payout sheet</a></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </section>
</div>
