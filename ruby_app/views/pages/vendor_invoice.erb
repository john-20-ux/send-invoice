<header class="preview-header">
  <div>
    <p class="eyebrow">Vendor payout</p>
    <h1><%= h(@vendor_summary["name"]) %></h1>
    <p class="muted" style="margin-top:8px">Generated on <%= format_datetime(Time.now.utc.iso8601) %></p>
  </div>
  <div class="preview-meta">
    <span>Total orders: <strong><%= @vendor_summary["total_orders"] %></strong></span>
    <span>Commission rate: <strong><%= @vendor_summary["commission_rate"] %>%</strong></span>
  </div>
</header>

<section class="section-card">
  <h2>Payout summary</h2>
  <div class="payout-hero">
    <div class="payout-net">
      <span class="payout-net-label">Net payable</span>
      <span class="payout-net-value"><%= format_money(@vendor_summary["net_payable"], "USD") %></span>
      <span class="payout-net-note">Commission less deductions</span>
    </div>
    <div class="payout-breakdown">
      <div class="payout-row">
        <span class="k">Gross revenue <small><%= @vendor_summary["total_orders"] %> orders</small></span>
        <span class="amt"><%= format_money(@vendor_summary["total_revenue"], "USD") %></span>
      </div>
      <div class="payout-row">
        <span class="k">Commission <small>@ <%= @vendor_summary["commission_rate"] %>%</small></span>
        <span class="amt"><%= format_money(@vendor_summary["total_commission"], "USD") %></span>
      </div>
      <div class="payout-row">
        <span class="k">Deductions</span>
        <span class="amt neg">&minus;<%= format_money(@vendor_summary["custom_deductions"], "USD") %></span>
      </div>
      <div class="payout-row payout-row-total">
        <span class="k">Net payable</span>
        <span class="amt"><%= format_money(@vendor_summary["net_payable"], "USD") %></span>
      </div>
    </div>
  </div>
  <p class="section-note" style="margin-top:16px">Use the browser print dialog to save this payout sheet as a PDF.</p>
</section>
