#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

cd "$ROOT_DIR"

export DATABASE_PATH="${DATABASE_PATH:-$ROOT_DIR/ruby_app/db/send_invoice.sqlite3}"
export BACKGROUND_BACKEND="${BACKGROUND_BACKEND:-db_queue}"

echo "Starting WEBrick app with BACKGROUND_BACKEND=${BACKGROUND_BACKEND}"
echo "DATABASE_PATH=${DATABASE_PATH}"

exec bundle exec ruby app.rb
